# IVR Lab Environment Configuration
# Copy this file to .env and update the values

# =============================================================================
# NETWORK CONFIGURATION (REQUIRED)
# =============================================================================

# Your host machine's LAN IP address
# Find it with: ipconfig (Windows) or ip addr (Linux)
# This is needed for SIP clients to receive audio (NAT/SDP rewriting)
EXTERNAL_IP=192.168.64.1

# =============================================================================
# SIP TRUNK CONFIGURATION (REQUIRED per client)
# =============================================================================

# IP address of the client's PBX / contact center that sends calls to this IVR
# e.g. Avaya IP Office, Cisco CUCM, FreePBX, etc.
SIP_TRUNK_IP=172.16.70.23

# SIP port of the trunk (default: 5060)
SIP_TRUNK_PORT=5060

# Internal name for the trunk endpoint in Asterisk (default: ipoffice)
# SIP_TRUNK_NAME=ipoffice

# Asterisk dialplan context for inbound trunk calls (default: from-ipoffice)
# SIP_TRUNK_CONTEXT=from-ipoffice

# =============================================================================
# DOCKER REGISTRY (for production / pre-built images)
# =============================================================================

# Container registry prefix
REGISTRY=185.163.125.167:8888/ivr-lab

# Image tag to pull (default: latest)
# IMAGE_TAG=latest

# =============================================================================
# API KEYS (OPTIONAL)
# =============================================================================

# ElevenLabs API key for text-to-speech prompt generation
# Get one at https://elevenlabs.io
ELEVENLABS_API_KEY=

# =============================================================================
# SECURITY (CHANGE IN PRODUCTION)
# =============================================================================

# JWT secret for API authentication
JWT_SECRET=change-this-in-production-use-strong-secret

# =============================================================================
# IVR SETTINGS (OPTIONAL)
# =============================================================================

# IVR language: "ar" for Arabic (default), "en" for English
# IVR_LANGUAGE=ar
